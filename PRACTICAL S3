#include <stdio.h>

int main()
{
    int queue[10];
    int front = 0, rear = -1;
    int n, i;

    printf("Enter the number of processes: ");
    scanf("%d", &n);

    printf("Enter Process IDs:\n");

    for(i = 0; i < n; i++)
    {
        scanf("%d", &queue[++rear]);
    }

    printf("\nReady Queue:\n");

    for(i = front; i <= rear; i++)
    {
        printf("P%d ", queue[i]);
    }

    printf("\n");

    return 0;
}
