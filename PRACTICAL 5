#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>

int main()
{
    int file;
    char message[] = "Hello, Operating Systems!";
    char buffer[100];
    file = open("sample.txt", O_CREAT | O_WRONLY, 0644);  
    write(file, message, sizeof(message));
    close(file);
    file = open("sample.txt", O_RDONLY);
    read(file, buffer, sizeof(buffer));

    // Display the data
    printf("Data in file: %s\n", buffer);

    // Close the file
    close(file);

    return 0;
}
